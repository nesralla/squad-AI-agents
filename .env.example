# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Telegram ──────────────────────────────────────────────────────────────────
# Token from @BotFather
TELEGRAM_BOT_TOKEN=123456789:AAF...

# Comma-separated list of allowed chat IDs (leave blank to allow all)
# Get your chat ID by messaging @userinfobot on Telegram
TELEGRAM_ALLOWED_CHAT_IDS=123456789,987654321

# ── Git repository ────────────────────────────────────────────────────────────
# HTTPS URL of the GoLang repository the agents will push code to
GIT_REPO_URL=https://github.com/nesralla/temaquinobairroapp.git

# Personal access token with repo write permission (GitHub / GitLab)
GIT_TOKEN=ghp_...

# Identity used in commits
GIT_USERNAME=IA Dev Squad
GIT_EMAIL=ia-squad@devbot.local

# Branch to base feature branches on (default: main)
GIT_MAIN_BRANCH=main

# Path inside the container where the repo will be cloned
GIT_REPO_PATH=/tmp/ia-squad-repo

# ── Database (override only if running outside Docker Compose) ─────────────────
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/ai_squad

# ── Redis (override only if running outside Docker Compose) ───────────────────
REDIS_URL=redis://redis:6379

# ── Memory / Embeddings (Phase 3) ────────────────────────────────────────────
# Voyage AI API key (get free at https://dash.voyageai.com/)
# If blank, memory features are disabled and agents work as before
VOYAGE_API_KEY=pa-...

# Embedding model (default: voyage-code-3, optimised for code)
EMBEDDING_MODEL=voyage-code-3

# Enable/disable memory system (default: true)
MEMORY_ENABLED=true

# ── Jira Cloud Integration ────────────────────────────────────────────────────
# Enable Jira polling (default: false)
JIRA_ENABLED=false

# Your Atlassian Cloud domain (e.g. https://your-company.atlassian.net)
JIRA_BASE_URL=https://your-domain.atlassian.net

# Atlassian account email used for API authentication
JIRA_USER_EMAIL=you@company.com

# API token — generate at https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=ATATT3x...

# Jira project key to monitor (e.g. "DEV", "SQUAD", "AI")
JIRA_PROJECT_KEY=DEV

# How often to poll Jira for new issues (seconds, default: 60)
JIRA_POLL_INTERVAL=60

# Jira workflow status names (must match your board's column names)
JIRA_STATUS_TODO=To Do
JIRA_STATUS_IN_PROGRESS=In Progress
JIRA_STATUS_DONE=Done

# Only issues with this label will be picked up by the AI squad
# Add "ai-squad" label in Jira to trigger processing
JIRA_LABEL_TRIGGER=ai-squad

# ── Internal API URL used by the bot container ────────────────────────────────
API_BASE_URL=http://api:8000
